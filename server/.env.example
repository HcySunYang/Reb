# Reb Server Configuration

# Port to listen on (default: 7680)
PORT=7680

# Bcrypt-hashed auth token. Generate one with:
#   npm run generate-token
AUTH_TOKEN_HASH=

# Optional: full path to claude binary (auto-detected if not set)
# CLAUDE_PATH=/usr/local/bin/claude

# Optional: TLS configuration for wss:// (not needed with Tailscale)
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem
